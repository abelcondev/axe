{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "src",
    "baseUrl": ".",
    "lib": ["ES2023"],
    "composite": true,
    "types": ["node", "vitest/globals"],
    "paths": {
      "@axe/core": ["../core/index.ts"],
      "@axe/core/*": ["../core/*"]
    }
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist"],
  "references": [{ "path": "../core" }]
}
